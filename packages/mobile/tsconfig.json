{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-native",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@mobile/*": ["./src/*"],
      "@power-budget/core": ["../../packages/core/src/index.ts"],
      "@power-budget/core/*": ["../../packages/core/src/*"],
      "@power-budget/shared-app": ["../../packages/shared-app/src/index.ts"],
      "@power-budget/shared-app/*": ["../../packages/shared-app/src/*"],
      "@power-budget/design-tokens": ["../../packages/design-tokens/src/index.ts"],
      "@power-budget/design-tokens/rn": ["../../packages/design-tokens/src/rn.ts"]
    }
  },
  "include": ["src", "index.ts", "app.json"]
}
