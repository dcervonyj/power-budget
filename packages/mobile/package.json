{
  "name": "@power-budget/mobile",
  "private": true,
  "version": "0.0.1",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "echo 'No tests yet' && exit 0",
    "i18n:extract": "formatjs extract 'src/**/*.{ts,tsx}' --out-file assets/locales/en.json --format simple --id-interpolation-pattern '[sha512:contenthash:base64:6]'"
  },
  "dependencies": {
    "@power-budget/core": "workspace:*",
    "@power-budget/design-tokens": "workspace:^",
    "@power-budget/shared-app": "workspace:*",
    "@react-navigation/bottom-tabs": "^7.16.1",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/native-stack": "^6.9.0",
    "@sentry/react-native": "^8.11.1",
    "expo": "~51.0.0",
    "expo-secure-store": "~13.0.0",
    "expo-status-bar": "~1.12.0",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.7",
    "react": "18.2.0",
    "react-intl": "^10.1.7",
    "react-native": "0.74.0",
    "react-native-safe-area-context": "4.10.0",
    "react-native-screens": "~3.31.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@formatjs/cli": "^6.16.0",
    "@formatjs/cli-lib": "^8.7.0",
    "@types/node": "^25.8.0",
    "@types/react": "~18.2.0",
    "@types/react-native": "~0.73.0",
    "eslint-plugin-formatjs": "^6.4.10",
    "typescript": "^5.5.0"
  }
}
