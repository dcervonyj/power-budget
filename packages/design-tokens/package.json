{
  "name": "@power-budget/design-tokens",
  "version": "0.0.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./css": "./dist/css.js",
    "./rn": "./dist/rn.js"
  },
  "scripts": {
    "build": "tsc -b && node dist/css.js > dist/tokens.css",
