{
  "name": "@power-budget/web",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist .turbo",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep smoke",
    "i18n:extract": "formatjs extract 'src/**/*.{ts,tsx}' --out-file public/locales/en.json --format simple --id-interpolation-pattern '[sha512:contenthash:base64:6]'"
  },
  "dependencies": {
    "@power-budget/core": "workspace:*",
    "@power-budget/design-tokens": "workspace:^",
    "@power-budget/shared-app": "workspace:*",
    "@sentry/react": "^10.53.1",
    "mobx": "^6.13.0",
    "mobx-react-lite": "^4.0.7",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^10.1.7",
    "react-router-dom": "^6.26.0"
  },
  "devDependencies": {
    "@formatjs/cli": "^6.16.0",
    "@formatjs/cli-lib": "^8.7.0",
    "@playwright/test": "^1.60.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint-plugin-formatjs": "^6.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.0",
    "vite": "^6.4.2",
    "vitest": "^2.1.9"
  }
}
