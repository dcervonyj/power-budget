{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "outDir": "dist",
    "paths": {
      "@web/*": ["./src/*"]
    }
  },
  "include": ["src", "vite.config.ts"]
}
