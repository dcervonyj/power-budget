  "info": {
    "title": "Power Budget API",
    "description": "",
    "version": "1.0",
    "contact": {}
  },
  "tags": [],
  "servers": [],
  "components": {
    "securitySchemes": {
      "bearer": {
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "type": "http"
      }
    },
    "schemas": {
      "RegisterDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "Str0ngPass!",
            "minLength": 8
          },
          "locale": {
            "type": "string",
            "enum": ["en", "uk", "ru", "pl"],
            "default": "en"
          }
        },
        "required": ["email", "password"]
      },
      "LoginDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "Str0ngPass!"
          },
          "totp": {
            "type": "string",
            "description": "TOTP code if 2FA is enabled",
            "example": "123456"
          }
        },
        "required": ["email", "password"]
      },
      "RequestMagicLinkDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "user@example.com"
          }
        },
        "required": ["email"]
      },
      "ConsumeMagicLinkDto": {
        "type": "object",
        "properties": {
          "token": {
            "type": "string",
            "description": "Magic-link token from email"
          }
        },
        "required": ["token"]
      },
      "VerifyTotpDto": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "description": "6-digit TOTP code",
            "example": "123456"
          }
        },
        "required": ["code"]
      },
      "RefreshTokenDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Opaque refresh token"
          }
        },
        "required": ["refreshToken"]
      },
      "LogoutDto": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string",
            "description": "Refresh token to revoke"
          }
        },
        "required": ["refreshToken"]
      },
      "UpdateLocaleDto": {
        "type": "object",
        "properties": {
          "locale": {
            "type": "string",
            "enum": ["en", "uk", "ru", "pl"],
            "example": "en"
          }
        },
        "required": ["locale"]
      },
      "CreateHouseholdDto": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "example": "Smith Family"
          },
          "baseCurrency": {
            "type": "string",
            "example": "PLN",
            "description": "ISO 4217 currency code"
          }
        },
        "required": ["name"]
      },
      "InviteToHouseholdDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "example": "member@example.com"
          }
        },
        "required": ["email"]
      },
      "AddManualTransactionDto": {
        "type": "object",
        "properties": {
          "accountId": {
            "type": "string",
            "description": "Bank account ID"
          },
          "occurredOn": {
            "type": "string",
            "description": "Date of transaction (ISO 8601)",
            "example": "2024-06-15"
          },
          "amountMinor": {
            "type": "number",
            "description": "Amount in minor currency units (e.g. cents)",
            "example": 1500
          },
          "currency": {
            "type": "string",
            "description": "ISO 4217 currency code",
            "example": "PLN"
          },
          "description": {
            "type": "string",
            "example": "Coffee at Starbucks"
          },
          "merchant": {
            "type": "string",
            "example": "Starbucks",
            "nullable": true
          },
          "notes": {
            "type": "string",
            "example": "Team lunch",
            "nullable": true
          }
        },
        "required": ["accountId", "occurredOn", "amountMinor", "currency", "description"]
      },
      "PatchTransactionDto": {
        "type": "object",
        "properties": {
          "notes": {
            "type": "string",
            "example": "Corrected description",
            "nullable": true
          },
          "ignored": {
            "type": "boolean",
            "description": "Soft-ignore the transaction from totals"
          }
        }
      },
      "SetMappingDto": {
        "type": "object",
        "properties": {
          "plannedItemId": {
            "type": "string",
            "nullable": true,
            "description": "Planned item ID to map to, or null to unmap"
          }
        },
        "required": ["plannedItemId"]
      },
      "MarkTransferDto": {
        "type": "object",
        "properties": {
          "counterpartTransactionId": {
            "type": "string",
            "nullable": true,
            "description": "ID of the counterpart transaction for this transfer"
          }
        }
      },
      "BulkMapDto": {
        "type": "object",
        "properties": {
          "ids": {
            "description": "Transaction IDs to act on",
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "op": {
            "type": "string",
            "enum": ["map", "transfer", "ignore"]
          },
          "payload": {
            "type": "object",
            "description": "Operation-specific payload"
          }
        },
        "required": ["ids", "op"]
      },
      "InitiateBankConnectionDto": {
        "type": "object",
        "properties": {
          "provider": {
            "type": "string",
            "enum": ["gocardless", "wise_personal"]
          },
          "bankId": {
            "type": "string",
            "description": "Provider-specific institution/bank ID",
            "example": "PKO_BPKOPLPW"
          },
          "redirectUri": {
            "type": "string",
            "description": "OAuth redirect URI after consent",
            "example": "https://app.power-budget.test/connect/callback"
          }
        },
        "required": ["provider", "bankId", "redirectUri"]
      }
    }
  }
}
