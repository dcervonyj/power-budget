{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2022",
    "outDir": "dist",
    "rootDir": ".",
    "paths": {
      "@power-budget/core": ["../core/dist/index.d.ts"],
      "@power-budget/core/*": ["../core/dist/*"]
    }
  },
  "include": ["src/**/*", "drizzle/schema.ts"],
  "exclude": ["node_modules", "dist", "src/test/integration/**/*"]
}
