<mjml>
  <mj-head>
    <mj-title>Your Weekly Budget Summary</mj-title>
    <mj-attributes>
      <mj-all font-family="Arial, sans-serif" />
      <mj-text font-size="16px" line-height="1.5" color="#333333" />
    </mj-attributes>
  </mj-head>
  <mj-body background-color="#f4f4f4">
    <mj-section background-color="#ffffff" padding="20px">
      <mj-column>
        <mj-text font-size="22px" font-weight="bold" color="#2d6a4f">📊 Weekly Budget Summary</mj-text>
        <mj-divider border-color="#2d6a4f" border-width="2px" />
        <mj-text>Hi {{name}},</mj-text>
        <mj-text>
          Here is your spending summary for <strong>{{planName}}</strong>
          ({{periodStart}} — {{periodEnd}}):
        </mj-text>
        <mj-table>
          <tr style="background:#f0f0f0">
            <td style="padding:8px">Total Spent</td>
            <td style="padding:8px"><strong>{{totalSpent}} {{currency}}</strong></td>
          </tr>
          <tr>
            <td style="padding:8px">Total Planned</td>
            <td style="padding:8px"><strong>{{totalPlanned}} {{currency}}</strong></td>
          </tr>
        </mj-table>
        <mj-text color="#888888" font-size="13px">
          Log in to Power Budget to see a detailed breakdown.
        </mj-text>
      </mj-column>
    </mj-section>
  </mj-body>
</mjml>
