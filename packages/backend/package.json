{
  "name": "@power-budget/backend",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:worker": "node dist/worker.main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx drizzle/migrate.ts",
    "db:reset": "drizzle-kit drop && tsx drizzle/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx drizzle/seed/0001_seed_categories.ts",
    "test:integration": "vitest run --config src/test/integration/vitest.integration.config.ts",
    "generate:openapi": "tsx src/generate-openapi.ts",
    "check:openapi": "pnpm run generate:openapi && pnpm exec prettier --write openapi.json && git diff --exit-code openapi.json",
    "copy:i18n": "cp -r ../web/public/locales ./src/i18n/locales/"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.2",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^10",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11",
    "@nestjs/platform-fastify": "^11",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.4.3",
    "@power-budget/core": "workspace:*",
    "@sentry/node": "^10.53.1",
    "argon2": "^0.44.0",
    "bullmq": "^5.76.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "otplib": "^13.4.0",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2",
    "uuidv7": "^1.2.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10",
    "@nestjs/testing": "^10",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.0",
    "typescript": "^5",
    "vite": "^6",
    "vitest": "^2.0.0",
    "vitest-mock-extended": "^4.0.0"
  }
}
