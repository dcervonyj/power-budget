# Copy this file to .env for local development.
# DO NOT commit .env to git.
# These credentials are DEV-ONLY. Never use in staging or production.

# === Docker Compose service ports (override to avoid conflicts) ===
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# === Postgres credentials (dev-only) ===
POSTGRES_USER=power_budget
POSTGRES_PASSWORD=power_budget
POSTGRES_DB=power_budget

# === Application-level env vars (consumed by packages/backend & worker) ===
DATABASE_URL=postgres://power_budget:power_budget@localhost:5432/power_budget
REDIS_URL=redis://localhost:6379
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=Power Budget <noreply@power-budget.local>

# === Encryption ===
# Encryption KEK (32 random bytes, base64-encoded)
# Generate with: openssl rand -base64 32
ENCRYPTION_KEK=<run: openssl rand -base64 32>

# === Audit log PII redaction ===
# Amounts (in minor units) at or above this threshold are redacted in audit logs.
# 1000000 minor units = 10,000 in major units (e.g., 10,000 PLN)
AUDIT_REDACTION_THRESHOLD_MINOR=1000000

# === GoCardless (Bank Account Data API) ===
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
# Leave empty to disable (DSNs are project-specific secrets; get them from sentry.io)
SENTRY_DSN=
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=

# Web Sentry DSN
VITE_SENTRY_DSN=

# Mobile Sentry DSN
EXPO_PUBLIC_SENTRY_DSN=
